{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 5: Predict Tropism for a Novel Capsid\n",
    "\n",
    "**This is the end-user notebook.** Paste any AAV VP1 capsid sequence and get:\n",
    "- Tropism probability scores (CNS, Peripheral, Broad, BBB)\n",
    "- Comparison to known serotypes\n",
    "- Optional: full mutational scan to guide engineering\n",
    "\n",
    "Runs fully in mock mode without ESM-2 installation for demonstration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, os, numpy as np, pandas as pd\n",
    "sys.path.insert(0, '..')\n",
    "import matplotlib.pyplot as plt\n",
    "from src.models.mutational_scan import make_mock_embedder, make_mock_classifier, run_single_scan, vr_region_sensitivity\n",
    "from src.visualization.plots import plot_vr_sensitivity\n",
    "\n",
    "# ─── CONFIG: swap these for real ESM-2 + trained model ───────────────────────\n",
    "USE_MOCK = True  # Set False after: pip install fair-esm && python src/models/classifier.py --train\n",
    "\n",
    "if USE_MOCK:\n",
    "    print('[DEMO MODE] Using mock embedder — results are illustrative only')\n",
    "    embedder_fn = make_mock_embedder()\n",
    "    classifier_fn = make_mock_classifier()\n",
    "else:\n",
    "    import torch, esm\n",
    "    from src.models.classifier import load_model, predict_mlp\n",
    "    esm_model, alphabet = esm.pretrained.esm2_t33_650M_UR50D()\n",
    "    esm_model.eval()\n",
    "    batch_converter = alphabet.get_batch_converter()\n",
    "    def embedder_fn(seq):\n",
    "        data = [('q', seq[:1022])]\n",
    "        _, _, tokens = batch_converter(data)\n",
    "        with torch.no_grad():\n",
    "            results = esm_model(tokens, repr_layers=[33])\n",
    "        return results['representations'][33][0, 1:min(len(seq),1022)+1].mean(dim=0).numpy()\n",
    "    clf_model, scaler = load_model('../models/')\n",
    "    classifier_fn = lambda X: predict_mlp(clf_model, scaler, X)\n",
    "\n",
    "LABEL_COLS = ['cns', 'peripheral', 'broad', 'bbb']\n",
    "from src.visualization.plots import LABEL_COLORS\n",
    "print('Ready!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Enter Your Capsid Sequence\n",
    "\n",
    "Paste any VP1 amino acid sequence below. Examples:\n",
    "- Novel variant you are engineering\n",
    "- Natural serotype not in training set\n",
    "- Computationally designed capsid"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── EDIT THIS ───────────────────────────────────────────────────────────────\n",
    "QUERY_NAME = 'My_Novel_Capsid'\n",
    "QUERY_SEQUENCE = \"\"\"\n",
    "MAADGYLPDWLEDTLSEGIRQWWKLKPGPPPPKPAERHKDDSRGLVLPGYKYLGPFNGLDKGEPVNEADAAALEHDKAYDRQLDSGD\n",
    "NPYLKYNHADAEFQERLKEDTSFGGNLGRAVFQAKKRVLEPLGLVEEPVKTAPGKKRPVIHSPVEPDSSSGTGKAGQQPARKRLNFG\n",
    "QTGDADSVPDPQPLGQPPAGHGLTNMAGGGGAPMADNNEGADGVGNSSGNWHCDSTWMGDRVITTSTRTWALPTYNNHLYKQISSQS\n",
    "\"\"\".replace('\\n', '').strip()\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "print(f'Query: {QUERY_NAME}')\n",
    "print(f'Length: {len(QUERY_SEQUENCE)} aa')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Predict\n",
    "emb = embedder_fn(QUERY_SEQUENCE)\n",
    "probs = classifier_fn(emb[np.newaxis, :])[0]\n",
    "\n",
    "print(f'\\n=== Tropism Predictions for {QUERY_NAME} ===')\n",
    "print(f'{\"-\"*40}')\n",
    "for label, prob in zip(LABEL_COLS, probs):\n",
    "    bar = '█' * int(prob * 20)\n",
    "    flag = '← HIGH' if prob > 0.7 else ('← moderate' if prob > 0.4 else '')\n",
    "    print(f'{label:<12}: {prob:.3f}  {bar:<20} {flag}')\n",
    "print(f'{\"-\"*40}')\n",
    "print(f'Top prediction: {LABEL_COLS[int(np.argmax(probs))]}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visual bar chart\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "colors = [LABEL_COLORS.get(l, '#888') for l in LABEL_COLS]\n",
    "bars = ax.barh(LABEL_COLS, probs, color=colors, edgecolor='black', linewidth=0.8)\n",
    "ax.axvline(0.5, color='black', lw=1, ls='--', alpha=0.4, label='Decision threshold')\n",
    "for bar, prob in zip(bars, probs):\n",
    "    ax.text(min(prob + 0.02, 0.95), bar.get_y() + bar.get_height()/2,\n",
    "            f'{prob:.3f}', va='center', fontsize=11, fontweight='bold')\n",
    "ax.set_xlim(0, 1.1)\n",
    "ax.set_xlabel('Predicted Probability', fontsize=12)\n",
    "ax.set_title(f'Tropism Prediction: {QUERY_NAME}', fontsize=13, fontweight='bold')\n",
    "ax.legend()\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Optional: run mutational scan for engineering insights\n",
    "RUN_SCAN = True  # Set False to skip\n",
    "SCAN_POSITIONS = 100  # Increase for full capsid (slow)\n",
    "\n",
    "if RUN_SCAN:\n",
    "    print(f'Running mutational scan (first {SCAN_POSITIONS} positions)...')\n",
    "    scan_df = run_single_scan(\n",
    "        QUERY_SEQUENCE, embedder_fn, classifier_fn,\n",
    "        label_idx=3,  # BBB\n",
    "        max_positions=SCAN_POSITIONS,\n",
    "        verbose=True\n",
    "    )\n",
    "    \n",
    "    vr_sens = vr_region_sensitivity(scan_df)\n",
    "    os.makedirs('../results/figures', exist_ok=True)\n",
    "    plot_vr_sensitivity(vr_sens, '../results/figures/novel_capsid_vr.png',\n",
    "                        title=f'{QUERY_NAME} — Variable Region Sensitivity')\n",
    "    \n",
    "    from IPython.display import Image\n",
    "    Image('../results/figures/novel_capsid_vr.png', width=650)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if RUN_SCAN:\n",
    "    from src.models.mutational_scan import get_top_beneficial_mutations\n",
    "    top = get_top_beneficial_mutations(scan_df, top_n=10)\n",
    "    print(f'Top 10 single mutations predicted to increase BBB score:')\n",
    "    print(top.to_string(index=False))"
   ]
  }
 ],
